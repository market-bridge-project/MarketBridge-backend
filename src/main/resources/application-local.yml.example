spring:
  datasource:
    url: jdbc:mysql://localhost:3306/marketbridge
    username: root
    password: root1234
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: create   # 스키마 안정화되면 validate 로 변경 권장
    defer-datasource-initialization: true   # ddl-auto(create) 이후 data.sql 실행

  sql:
    init:
      mode: always   # MySQL(비임베디드)에서도 data.sql 실행

naver:
  ai:
    api-key: YOUR_NAVER_CLOVA_STUDIO_API_KEY
    base-url: https://clovastudio.stream.ntruss.com
    embedding-path: /testapp/v1/api-tools/embedding/v2
    embedding-model: clir-emb-dolphin
